# ==========================================
# Agent System Configuration
# ==========================================
# Copy this file to .env and fill in your values.

# --- LLM Provider ---
# Options: anthropic | openai | gemini | ollama | deepseek
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# --- Provider-Specific Notes ---
# Anthropic:  LLM_API_KEY=sk-ant-...  LLM_MODEL=claude-sonnet-4-20250514
# OpenAI:     LLM_API_KEY=sk-...      LLM_MODEL=gpt-4o
# Gemini:     LLM_API_KEY=AI...       LLM_MODEL=gemini-2.0-flash
# DeepSeek:   LLM_API_KEY=sk-...      LLM_MODEL=deepseek-chat  LLM_BASE_URL=https://api.deepseek.com
# Ollama:     LLM_API_KEY=             LLM_MODEL=llama3        LLM_BASE_URL=http://localhost:11434/v1

# --- Reflection (optional: use a different/cheaper model for reflection) ---
REFLECTION_PROVIDER=
REFLECTION_MODEL=

# --- Logging ---
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# LOG_FORMAT: console (colored, human-readable) | json (structured, machine-parsable)
LOG_FORMAT=console
LOG_FILE=logs/agent.log

# --- Observability (OpenTelemetry) ---
# Leave empty for console-only tracing. Set for OTLP export (e.g. Jaeger, Grafana Tempo).
OTLP_ENDPOINT=
SERVICE_NAME=agent-system

# --- MCP ---
MCP_REGISTRY_PATH=config/mcp_registry.json

# --- Storage Paths ---
SKILLS_DIR=skills
BRAIN_DB_PATH=brain/episodes.db
BRAIN_CHROMA_PATH=brain/chroma
